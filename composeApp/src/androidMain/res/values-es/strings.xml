    <string name="help_center_faq_header">Preguntas frecuentes</string>
    <string name="help_flame_bubble_collapsed">¡Hola! Soy Llamita.\n¿Cómo puedo ayudarte?\nHaz clic en una tarjeta para ver los detalles.</string>
    <string name="help_flame_bubble_expanded">¡Así es! Si no encuentras la respuesta aquí, haz clic en mí y resolveremos el problema juntos.</string>
