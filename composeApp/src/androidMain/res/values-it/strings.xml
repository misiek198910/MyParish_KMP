    <string name="help_center_faq_header">Domande frequenti</string>
    <string name="help_flame_bubble_collapsed">Ciao! Sono Fiammella.\nCome posso aiutarti?\nClicca su una scheda per i dettagli.</string>
    <string name="help_flame_bubble_expanded">Proprio così! Se non trovi la risposta qui, clicca su di me e risolveremo il problema insieme.</string>
