    <string name="welcome_text1">Welcome to My Parish!</string>
    <string name="welcome_text2">To fully utilize the app, we need your consent:</string>
    <string name="welcome_text3">• Location permission: required for the &apos;find me&apos; and &apos;find nearest parish&apos; features.</string>
    <string name="welcome_text4">• Ads consent: allows us to display personalized ads, which supports the maintenance and development of the app. Your data is secure.</string>
    <string name="welcome_text5">I understand, continue</string>
    <string name="welcome_text6">• Notifications permission: allows us to send notifications about Masses.</string>
    <string name="welcome_text7">The app must run in the background for notifications to be timely and accurate.</string>
    <string name="welcome_welcome_text_3">Finally, to set Mass reminders, the app requires special permission to schedule exact alarms.</string>

